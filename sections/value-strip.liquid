<section class="section-shell">
  <div class="value-strip">
    {% for block in section.blocks %}
      <article class="value-strip__item" {{ block.shopify_attributes }}>
        <p class="eyebrow">{{ block.settings.kicker }}</p>
        <h2>{{ block.settings.heading }}</h2>
        <p>{{ block.settings.copy }}</p>
      </article>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Value strip",
  "max_blocks": 3,
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        { "type": "text", "id": "kicker", "label": "Kicker", "default": "Testing" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Verified identity" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Show batch-backed testing, endotoxin screening, and purity verification with confidence." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Value strip",
      "blocks": [
        { "type": "value", "settings": { "kicker": "Testing", "heading": "Verified identity", "copy": "Show batch-backed testing, endotoxin screening, and purity verification with confidence." } },
        { "type": "value", "settings": { "kicker": "Shipping", "heading": "Fast fulfillment", "copy": "Use this area for shipping windows, tracking expectations, and support response times." } },
        { "type": "value", "settings": { "kicker": "Support", "heading": "Clear buying path", "copy": "Guide visitors from discovery to catalog, COAs, FAQs, and contact without clutter." } }
      ]
    }
  ]
}
{% endschema %}
