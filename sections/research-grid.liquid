<section class="section-shell research-grid">
  <div class="section-heading">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h2>{{ section.settings.heading }}</h2>
    <div class="section-copy">{{ section.settings.copy }}</div>
  </div>
  <div class="research-grid__cards">
    {% for block in section.blocks %}
      <article class="research-grid__card" {{ block.shopify_attributes }}>
        <p class="eyebrow">{{ block.settings.kicker }}</p>
        <h3>{{ block.settings.heading }}</h3>
        <p>{{ block.settings.copy }}</p>
        {% if block.settings.link_label != blank and block.settings.link_url != blank %}
          <a class="text-link" href="{{ block.settings.link_url }}">{{ block.settings.link_label }}</a>
        {% endif %}
      </article>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Research grid",
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "text", "id": "kicker", "label": "Kicker", "default": "COA access" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Batch documentation" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Link to certificates, lab results, and policies that help serious buyers verify what they need." },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Learn more" },
        { "type": "url", "id": "link_url", "label": "Link URL" }
      ]
    }
  ],
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Trust architecture" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Everything important surfaced faster" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "This section replaces clutter with clear proof points and directional pages that help visitors move with confidence." }
  ],
  "presets": [
    {
      "name": "Research grid",
      "blocks": [
        { "type": "card", "settings": { "kicker": "COA access", "heading": "Batch documentation", "copy": "Link to certificates, lab results, and policies that help serious buyers verify what they need.", "link_label": "Open COAs" } },
        { "type": "card", "settings": { "kicker": "FAQ", "heading": "Purchase guidance", "copy": "Answer key questions about shipping, product handling, and order flow before support tickets pile up.", "link_label": "Read FAQs" } },
        { "type": "card", "settings": { "kicker": "Support", "heading": "Direct contact", "copy": "Make it easy for buyers to reach you when they need help with a batch, order, or catalog question.", "link_label": "Contact team" } }
      ]
    }
  ]
}
{% endschema %}
